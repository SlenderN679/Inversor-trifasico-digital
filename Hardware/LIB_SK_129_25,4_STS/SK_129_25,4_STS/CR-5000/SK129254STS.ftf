                  (line
                    (vertex
                      (pt 3370000 -1250000
                        (width 10000)
                      )
                      (pt 3370000 1250000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
              (line
                (geometry
                  (line
                    (vertex
                      (pt 3370000 1250000
                        (width 10000)
                      )
                      (pt -830000 1250000
                        (width 10000)
                      )
                    )
                  )
                )
              )
            )
            (layer (footLayer Assembly-Top)
